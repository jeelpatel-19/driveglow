# ─────────────────────────────────────────────────────────────
#  DriveGlow — Environment Variable Template
#  Copy this file to .env and fill in real values for local dev.
#  On Railway: add these in Dashboard → your service → Variables.
# ─────────────────────────────────────────────────────────────

# Your Gmail address (used as the sender for all outgoing emails)
EMAIL_USER=yourgmail@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate at: myaccount.google.com/apppasswords
# Paste exactly as shown — spaces are stripped automatically.
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Email address that receives new booking alert notifications
# Can be the same as EMAIL_USER
OWNER_EMAIL=yourgmail@gmail.com
