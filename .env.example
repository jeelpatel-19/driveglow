# ─────────────────────────────────────────────────────────────
#  DriveGlow — Environment Variable Template
#  Copy to .env for local dev. On Railway: add in Dashboard → Variables.
# ─────────────────────────────────────────────────────────────

# EmailJS HTTP API credentials
# Get these from: https://dashboard.emailjs.com/admin
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_customer_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key

# Optional: separate template ID for owner notification emails
# If not set, EMAILJS_TEMPLATE_ID is used for both emails
# EMAILJS_OWNER_TEMPLATE_ID=your_owner_template_id

# Email address that receives new booking alert notifications
OWNER_EMAIL=your_email@gmail.com
